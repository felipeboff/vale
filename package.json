{
  "name": "@felipe.boff/vale",
  "version": "1.1.0",
  "description": "TypeScript-first runtime validator with coercion, composable schemas, and path-based error reporting",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "resolve": "tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "build": "npm run clean && tsc && npm run resolve",
    "example": "tsx examples/usage.ts",
    "release": "npm run build && npm publish",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "validation",
    "schema",
    "parser",
    "typescript",
    "runtime",
    "coercion"
  ],
  "author": "Felipe Boff (https://github.com/felipeboff)",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipeboff/vale.git"
  },
  "homepage": "https://github.com/felipeboff/vale#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
